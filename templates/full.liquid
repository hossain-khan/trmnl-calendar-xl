<div class="layout">
  {% if calendar != blank and events != blank %}
  <div class="flex flex--col gap--medium h--full">

    {% comment %} ============================================================
      HERO PANEL — NOW or NEXT (inverted, top 60% of layout height)
      Three <span data-value-fit> elements for device/orientation-appropriate heights:
        block lg:hidden                      → sm/md (TRMNL OG),        fit_height 150
        hidden lg:block lg:portrait:hidden   → lg landscape (TRMNL X),  fit_height 320
        hidden lg:portrait:block             → lg portrait  (TRMNL X),  fit_height 480
    ============================================================ {% endcomment %}
    {% assign hero_meta = primary_event_time_label %}
    <div class="rounded--large p--2 flex flex--col gap--small h--[60cqh] text--white bg--black">

      {% render "section_label", text: primary_label, meta: hero_meta, inverted: true %}

      {% if primary_event != blank %}
      <span class="value value--xxxlarge text--center block lg:hidden"
            data-value-fit="true"
            data-value-fit-max-height="150">{{ primary_event_display }}</span>
      <span class="value value--xxxlarge text--center hidden lg:block lg:portrait:hidden"
            data-value-fit="true"
            data-value-fit-max-height="320">{{ primary_event_display }}</span>
      <span class="value value--xxxlarge text--center hidden lg:portrait:block"
            data-value-fit="true"
            data-value-fit-max-height="480">{{ primary_event_display }}</span>
      {% else %}
      <div class="value value--xxxlarge">FREE</div>
      <div class="title title--small">No events today</div>
      {% endif %}

    </div>

    {% comment %} ============================================================
      BOTTOM ROW — NEXT (left) + LATER (right), grows to fill remaining space
    ============================================================ {% endcomment %}
    <div class="grid grid--cols-2 gap--medium grow">

      {% comment %} --- NEXT panel --- {% endcomment %}
      <div class="outline rounded--large p--2 flex flex--col gap--small">

        {% render "section_label", text: "NEXT", inverted: true %}

        {% if display_next_event != blank %}
        <div class="value text--center md:portrait:value--small lg:value--large lg:portrait:value--large" data-clamp="2">{{ next_event_display }}</div>
        <div class="value text--center value--small md:value--medium lg:value">{{ next_event_time_label }}</div>
        {% else %}
        <div class="title title--small">CLEAR</div>
        <div class="description">No timed events after this.</div>
        {% endif %}

      </div>

      {% comment %} --- LATER panel --- {% endcomment %}
      <div class="outline rounded--large p--2 flex flex--col gap--small">

        {% render "section_label", text: "LATER", inverted: true %}

        <div class="flex flex--col gap--xsmall lg:gap--small">
          {% assign later_count = 0 %}
          {% for event in events %}
            {% assign start_ts = event.start_full | date: '%s' | plus: 0 %}
            {% assign end_ts = event.end_full | date: '%s' | plus: 0 %}
            {% comment %}
              Eligibility timestamp: determines whether this event should appear in LATER.

              PROBLEM with all_day events: start_full is a bare date ("2026-03-18"), which
              Liquid's `date: '%s'` parses as midnight UTC. By mid-afternoon local time the
              UTC clock has already passed that midnight, so start_ts < now_ts and the event
              silently disappears — even if the event spans multiple future days.

              FIX: for all_day events, use end_ts instead. A multi-day all-day event like
              "Spring Break" (start: 2026-03-18, end: 2026-03-23) has an end_ts well in
              the future, so it correctly remains visible until the event is over.

              Timed events (all_day == false) use start_ts as usual — they have a full
              datetime in start_full (e.g. "2026-03-19T20:00:00.000-04:00") which parses
              correctly and is only in the past after the event has started.
            {% endcomment %}
            {% assign later_eligible_ts = start_ts %}
            {% if event.all_day %}{% assign later_eligible_ts = end_ts %}{% endif %}
            {% comment %}
              Skip events already shown in the hero (primary_event) or NEXT panel
              (display_next_event) to avoid duplicates. Matched by date_time + summary
              since there is no unique event ID in the payload.
            {% endcomment %}
            {% assign is_skip = false %}
            {% if primary_event != blank and event.date_time == primary_event.date_time and event.summary == primary_event.summary %}
              {% assign is_skip = true %}
            {% endif %}
            {% if display_next_event != blank and event.date_time == display_next_event.date_time and event.summary == display_next_event.summary %}
              {% assign is_skip = true %}
            {% endif %}
            {% if later_eligible_ts > now_ts and is_skip == false and later_count < later_limit %}
            <div class="item">
              <div class="meta"></div>
              <div class="content">
                <span class="title title--small md:title--medium lg:title--large" data-clamp="1">{% if trmnl.plugin_settings.custom_fields_values.capitalize_text == "false" %}{{ event.summary }}{% else %}{{ event.summary | upcase }}{% endif %}</span>
                {% assign event_date_label = event.start_full | date: '%b %-d' | upcase %}
                <span class="label label--small lg:label--base lg:label--outline">{% if event.all_day %}ALL DAY{% else %}{{ event.start }}{% endif %} · {{ event_date_label }}</span>
              </div>
            </div>
            {% assign later_count = later_count | plus: 1 %}
            {% endif %}
          {% endfor %}
          {% if later_count == 0 %}
          <div class="description">Nothing else scheduled.</div>
          {% endif %}
        </div>

      </div>

    </div>

  </div>
  {% else %}
  {% render "error_state", size: "full" %}
  {% endif %}
</div>

{% render "title_bar", title: current_date_label, instance: title_bar_status_full %}
