<div class="layout">
  {% if calendar != blank and events != blank %}
  <div class="flex flex--col gap--medium h--full">
    {% if primary_event != blank %}
      {% assign hero_meta = primary_event.start | append: " – " | append: primary_event.end %}
    {% else %}
      {% assign hero_meta = current_time_label %}
    {% endif %}
    {% render "now_panel", panel_classes: "rounded--large p--2 flex flex--col gap--small h--[60cqh] text--white bg--black", meta: hero_meta, event: primary_event, label: primary_label, value_classes: "value value--xxxlarge", fit_height: 150, fit_height_lg: 320, fit_height_lg_portrait: 480, empty_value: "FREE", empty_detail: "No events today", empty_detail_classes: "title title--small" %}

    {% if is_free and next_event != blank %}
    {% render "later_panel", panel_classes: "outline rounded--large p--2 flex flex--col gap--small grow w--full", events: events, next_event: next_event, now_ts: now_ts, later_limit: later_limit, wrapper_classes: "flex flex--col gap--xsmall lg:gap--small", title_classes: "title title--small md:title--medium lg:title--large", time_classes: "label", empty_text: "Nothing else scheduled.", item_style: "stacked", all_day_label: "ALL DAY", inverted: true %}
    {% else %}
    <div class="grid grid--cols-2 gap--medium">
      {% render "next_panel", panel_classes: "outline rounded--large p--2 flex flex--col gap--small", meta: current_date_label, next_event: next_event, title_classes: "value md:portrait:value--small lg:value--large lg:portrait:value--large", time_classes: "value value--small md:value--medium lg:value", inverted: true, empty_detail: "No timed events after this." %}

      <div class="outline rounded--large p--2 flex flex--col gap--small">
        {% render "later_items", events: events, next_event: next_event, now_ts: now_ts, later_limit: later_limit, wrapper_classes: "flex flex--col gap--xsmall lg:gap--small", title_classes: "title title--small md:title--medium lg:title--large", time_classes: "label label--small", empty_text: "Nothing else scheduled.", item_style: "stacked", all_day_label: "ALL DAY" %}
      </div>
    </div>
    {% endif %}
  </div>
  {% else %}
  {% render "error_state", size: "full" %}
  {% endif %}
</div>

{% render "title_bar", title: plugin_title, instance: calendar.event_layout | upcase %}
