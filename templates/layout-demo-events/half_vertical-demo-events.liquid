{% comment %}
  DEMO: half_vertical — active NOW event state.
  Two-row layout: TOP hero (NOW, ~67% height) | BOTTOM NEXT row (~33%)
  All HTML inlined (no render calls). Static data for responsive testing.

  Devices tested:
    TRMNL OG  (md, 400×480 effective) → 67cqh ≈ 292px → value budget ~200px → fit_height 200
    TRMNL X   (lg, 520×780 effective) → 67cqh ≈ 480px → value budget ~370px → fit_height 370

  Two-span strategy for responsive hero title:
    block lg:hidden  → visible on sm/md (TRMNL OG), hidden on lg+
    hidden lg:block  → hidden on sm/md, visible on lg+ (TRMNL X)
{% endcomment %}

<div class="layout">
  <div class="flex flex--col gap--small h--full">

    {% comment %} ============================================================
      TOP ROW — NOW hero (~67% of layout height)
    ============================================================ {% endcomment %}
    <div class="rounded--large p--2 flex flex--col gap--small h--[67cqh] text--white bg--black">

      {% comment %} Label row: section tag left, event time right {% endcomment %}
      <div class="flex flex--row flex--between flex--center-y gap--xsmall">
        <span class="label lg:label--large label--inverted">NOW</span>
        <span class="label lg:label--large label--inverted">2:15 PM – 3:15 PM</span>
      </div>

      {% comment %} Hero title — sm/md (TRMNL OG half_vertical ≈ 400×480) {% endcomment %}
      <span class="value value--xxxlarge block lg:hidden"
            data-value-fit="true"
            data-value-fit-max-height="200">MEET SAMANTHA AND EMILY AT DMS</span>

      {% comment %} Hero title — lg (TRMNL X half_vertical ≈ 520×780) {% endcomment %}
      <span class="value value--xxxlarge hidden lg:block"
            data-value-fit="true"
            data-value-fit-max-height="370">MEET SAMANTHA AND EMILY AT THE SCHOOL AND THEN MEET UP LATER</span>

    </div>

    {% comment %} ============================================================
      BOTTOM ROW — NEXT (grows to fill remaining ~33%)
    ============================================================ {% endcomment %}
    <div class="outline rounded--large p--2 flex flex--col gap--xsmall grow">

      {% comment %} Section label {% endcomment %}
      <span class="label lg:label--large label--underline">NEXT</span>

      {% comment %} Event title — scales up on TRMNL X {% endcomment %}
      <div class="title title--small md:title--medium lg:title--large" data-clamp="2">HOSSAIN BADMINTON 🏸</div>

      {% comment %} Event time {% endcomment %}
      <div class="value value--xsmall md:value--small lg:value--medium value--tnums">8:00 PM – 9:30 PM</div>

    </div>

  </div>
</div>

<div class="title_bar">
  <span class="title md:title--large">Calendar XL</span>
  <span class="instance">DEMO · NOW ACTIVE</span>
</div>
