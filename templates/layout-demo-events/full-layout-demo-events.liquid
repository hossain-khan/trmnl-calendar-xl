{% comment %}
  DEMO: full.liquid — active NOW event state.
  All HTML inlined (no render calls). Static data for responsive testing.

  Devices tested:
    TRMNL OG  (md, 800×480)  → layout ~436px tall → 60cqh ≈ 262px → value budget ~210px → fit_height 150
    TRMNL X   (lg, 1040×780) → layout ~716px tall → 60cqh ≈ 430px → value budget ~380px → fit_height 290

  Approach for responsive hero title:
    Three <span data-value-fit> elements, each with device/orientation-appropriate fit_height.
    block lg:hidden            → sm/md (TRMNL OG), fit_height 150
    hidden lg:block lg:portrait:hidden → lg landscape (TRMNL X), fit_height 320
    hidden lg:portrait:block   → lg portrait (TRMNL X portrait), fit_height 480
{% endcomment %}

<div class="layout">
  <div class="flex flex--col gap--medium h--full">

    {% comment %} ============================================================
      HERO PANEL — NOW (inverted, top 50% of layout height)
    ============================================================ {% endcomment %}
    <div class="rounded--large p--2 flex flex--col gap--small h--[60cqh] text--white bg--black">

      {% comment %} Label row: section tag left, event time right {% endcomment %}
      <div class="flex flex--row flex--between flex--center-y gap--xsmall">
        <span class="label lg:label--large label--inverted">NOW</span>
        <span class="label lg:label--large label--inverted">2:15 PM – 3:15 PM</span>
      </div>

      {% comment %} Hero title — sm/md devices (hidden on TRMNL X) {% endcomment %}
      <span class="value value--xxxlarge text--center block lg:hidden"
            data-value-fit="true"
            data-value-fit-max-height="150">MEET SAMANTHA AND EMILY AT DMS</span>

      {% comment %} Hero title — lg landscape (hidden on sm/md and lg portrait) {% endcomment %}
      <span class="value value--xxxlarge text--center hidden lg:block lg:portrait:hidden"
            data-value-fit="true"
            data-value-fit-max-height="320">MEET SAMANTHA AND EMILY AT THE SCHHOL AND THEN MEET UP LATER</span>

      {% comment %} Hero title — lg portrait / TRMNL X portrait (larger budget) {% endcomment %}
      <span class="value value--xxxlarge text--center hidden lg:portrait:block"
            data-value-fit="true"
            data-value-fit-max-height="480">MEET SAMANTHA AND EMILY AT THE SCHHOL AND THEN MEET UP LATER</span>

    </div>

    {% comment %} ============================================================
      BOTTOM ROW — NEXT (left) + LATER (right), grows to fill remaining space
    ============================================================ {% endcomment %}
    <div class="grid grid--cols-2 gap--medium grow">

      {% comment %} --- NEXT panel --- {% endcomment %}
      <div class="outline rounded--large p--2 flex flex--col gap--small">

        {% comment %} Section label row {% endcomment %}
        <div class="flex flex--row flex--between flex--center-y gap--xsmall">
          <span class="label lg:label--large label--inverted">NEXT</span>
        </div>

        {% comment %} Event title — scales up on larger screens {% endcomment %}
        <div class="value text--center md:portrait:value--small lg:value--large lg:portrait:value--large" data-clamp="2">HOSSAIN BADMINTON 🏸 Outside</div>

        {% comment %} Event time {% endcomment %}
        <div class="value text--center value--small md:value--medium lg:value">8:00 PM – 9:30 PM</div>

      </div>

      {% comment %} --- LATER panel --- {% endcomment %}
      <div class="outline rounded--large p--2 flex flex--col gap--small">

        {% comment %} Section label row {% endcomment %}
        <div class="flex flex--row flex--between flex--center-y gap--xsmall">
          <span class="label lg:label--large label--inverted">LATER</span>
        </div>

        {% comment %} Later items list — gap scales up on lg {% endcomment %}
        <div class="flex flex--col gap--xsmall lg:gap--small">

          <div class="item">
            <div class="meta"></div>
            <div class="content">
              <span class="title title--small md:title--medium lg:title--large" data-clamp="1">GO TO BRAMPTON FOR EID</span>
              <span class="label label--small lg:label--base lg:label--outline">ALL DAY · MAR 19</span>
            </div>
          </div>

          <div class="item">
            <div class="meta"></div>
            <div class="content">
              <span class="title title--small md:title--medium lg:title--large" data-clamp="1">BLUE BOX AND GREEN BIN</span>
              <span class="label label--small lg:label--base lg:label--outline">ALL DAY · MAR 20</span>
            </div>
          </div>

          <div class="item">
            <div class="meta"></div>
            <div class="content">
              <span class="title title--small md:title--medium lg:title--large" data-clamp="1">HOCKEY WITH THE BOYS</span>
              <span class="label label--small lg:label--base lg:label--outline">7:00 PM · MAR 18</span>
            </div>
          </div>

        </div>
      </div>

    </div>

  </div>
</div>

<div class="title_bar">
  <span class="title">Calendar XL</span>
  <span class="instance">DEMO · NOW ACTIVE</span>
</div>
