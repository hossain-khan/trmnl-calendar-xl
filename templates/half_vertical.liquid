<div class="layout">
  {% if calendar != blank and events != blank %}
  {% assign hero_meta = primary_event_time_label %}
  <div class="flex flex--col gap--small h--full">

    {% comment %} ============================================================
      TOP ROW — NOW/NEXT hero (~67% of layout height)
      Four <span data-value-fit> for device + orientation combinations:
        block portrait:hidden lg:hidden                  → md landscape (TRMNL OG),      fit_height 200
        hidden portrait:block lg:hidden lg:portrait:hidden → md portrait (TRMNL OG),     fit_height 120
          ↑ lg:portrait:hidden is required: portrait:block fires on ALL portrait sizes
            including lg, and it overrides lg:hidden due to CSS cascade order in the
            framework stylesheet. The compound query lg:portrait:hidden has higher
            specificity and definitively hides this span on lg portrait devices.
        hidden lg:block lg:portrait:hidden               → lg landscape (TRMNL X),       fit_height 370
        hidden lg:portrait:block                         → lg portrait  (TRMNL X),       fit_height 280
    ============================================================ {% endcomment %}
    <div class="rounded--large p--2 flex flex--col gap--small h--[67cqh] text--white bg--black">

      {% render "section_label", text: primary_label, meta: hero_meta, inverted: true %}

      {% if primary_event != blank %}
      <span class="value value--xxxlarge block portrait:hidden lg:hidden"
            data-value-fit="true"
            data-value-fit-max-height="200">{{ primary_event_display }}</span>
      <span class="value value--xxxlarge hidden portrait:block lg:hidden lg:portrait:hidden"
            data-value-fit="true"
            data-value-fit-max-height="120">{{ primary_event_display }}</span>
      <span class="value value--xxxlarge hidden lg:block lg:portrait:hidden"
            data-value-fit="true"
            data-value-fit-max-height="370">{{ primary_event_display }}</span>
      <span class="value value--xxxlarge hidden lg:portrait:block"
            data-value-fit="true"
            data-value-fit-max-height="220">{{ primary_event_display }}</span>
      {% else %}
      <div class="value value--xxxlarge">FREE</div>
      <div class="description">Nothing scheduled today</div>
      {% endif %}

    </div>

    {% comment %} ============================================================
      BOTTOM ROW — NEXT (grows to fill remaining ~33%)
    ============================================================ {% endcomment %}
    <div class="outline rounded--large p--2 flex flex--col gap--xsmall grow">

      {% render "section_label", text: "NEXT", inverted: false %}

      {% if display_next_event != blank %}
      <div class="value value--xsmall md:value--small lg:value--base" data-clamp="2">{{ next_event_display }}</div>
      <div class="value md:value--xsmall lg:value--medium">{{ next_event_time_label }}</div>
      {% else %}
      <div class="title title--small">CLEAR</div>
      {% endif %}

    </div>

  </div>
  {% else %}
  {% render "error_state", size: "half" %}
  {% endif %}
</div>

{% render "title_bar", title: current_date_label, instance: title_bar_status %}
