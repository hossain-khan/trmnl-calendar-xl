<div class="layout">
  {% if calendar != blank and events != blank %}
  {% if primary_event != blank %}
    {% assign hero_meta = primary_event.start | append: " – " | append: primary_event.end %}
  {% else %}
    {% assign hero_meta = blank %}
  {% endif %}
  <div class="flex flex--col gap--small h--full">

    {% render "now_panel", panel_classes: "rounded--large p--2 flex flex--col gap--small h--[67cqh] text--white bg--black", meta: hero_meta, event: primary_event, label: primary_label, value_classes: "value value--xxxlarge", fit_height: 200, fit_height_lg: 370, empty_value: "FREE", empty_detail: "Nothing scheduled today", empty_detail_classes: "description" %}

    {% render "next_panel", panel_classes: "outline rounded--large p--2 flex flex--col gap--xsmall grow", next_event: display_next_event, title_classes: "value value--xsmall md:value--small lg:value--base", time_classes: "value md:value--xsmall lg:value--medium", inverted: false, empty_detail: "Nothing next." %}

  </div>
  {% else %}
  {% render "error_state", size: "half" %}
  {% endif %}
</div>

{% render "title_bar", title: plugin_title, instance: "Top / Bottom" %}
