{% comment %}
  Shared components for Calendar XL.

  The calendar data source is selected by the user via the `calendar_source`
  custom field (plugin_instance_select, plugin_keyname: google_calendar).
  Templates reference it as `calendar_source` — no hardcoded merge namespace needed.
{% endcomment %}

{% template error_state %}
{% if size == 'full' %}
<div class="flex flex--col flex--center-x flex--center-y gap--medium h--full text--center">
  <div class="value value--large md:value--xlarge lg:value--xxlarge">CAL</div>
  <div class="title title--medium md:title--large">Calendar Merge Required</div>
  <div class="description md:title md:title--small">
    Connect a native calendar plugin, hide it in your playlist, then update this template to use the merge node from TRMNL.
  </div>
</div>
{% elsif size == 'half' %}
<div class="flex flex--col flex--center-x flex--center-y gap--small h--full text--center">
  <div class="value value--medium md:value--large">CAL</div>
  <div class="title title--small md:title--medium">Merge Required</div>
  <div class="description">Connect calendar data</div>
</div>
{% elsif size == 'quadrant' %}
<div class="flex flex--col flex--center-x flex--center-y gap--xsmall h--full text--center">
  <div class="value value--small md:value--medium">CAL</div>
  <div class="description">Need merge data</div>
</div>
{% endif %}
{% endtemplate %}

{% template section_label %}
<div class="flex flex--row flex--between flex--center-y gap--xsmall">
  <span class="label {% if inverted %}label--small label--inverted{% else %}label label--small label--underline{% endif %}">
    {% if icon and icon != blank %}{{ icon }} {% endif %}{{ text }}
  </span>
  {% if meta and meta != blank %}
  <span class="label label--small {% if inverted %}label--inverted{% endif %}">{{ meta }}</span>
  {% endif %}
</div>
{% endtemplate %}

{% template now_panel %}
<div class="{{ panel_classes }}">
  {% render "section_label", text: "NOW", meta: meta, inverted: true, icon: icon %}
  {% if current_event != blank %}
  <div class="{{ value_classes }}" data-value-fit="true" data-value-fit-max-height="{{ fit_height }}">{{ current_event.summary | upcase }}</div>
  <div class="{{ detail_classes }}">{{ current_event.start }} - {{ current_event.end }}</div>
  {% else %}
  <div class="{{ empty_value_classes | default: value_classes }}">{{ empty_value | default: 'FREE' }}</div>
  {% if empty_detail and empty_detail != blank %}
  <div class="{{ empty_detail_classes | default: detail_classes }}">{{ empty_detail }}</div>
  {% endif %}
  {% endif %}
</div>
{% endtemplate %}

{% template next_panel %}
<div class="{{ panel_classes }}">
  {% render "section_label", text: "NEXT", meta: meta, inverted: false, icon: icon %}
  {% if next_event != blank %}
  <div class="{{ title_classes }}" data-clamp="2">{{ next_event.summary | upcase }}</div>
  <div class="{{ time_classes }}">{{ next_event.start }} - {{ next_event.end }}</div>
  {% else %}
  <div class="{{ empty_title_classes | default: title_classes }}">{{ empty_title | default: 'CLEAR' }}</div>
  {% if empty_detail and empty_detail != blank %}
  <div class="{{ empty_detail_classes | default: 'description' }}">{{ empty_detail }}</div>
  {% endif %}
  {% endif %}
</div>
{% endtemplate %}

{% template later_items %}
<div class="{{ wrapper_classes }}">
  {% assign later_count = 0 %}
  {% for event in events %}
    {% assign start_ts = event.start_full | date: '%s' | plus: 0 %}
    {% assign is_next_match = false %}
    {% if next_event != blank and event.date_time == next_event.date_time and event.summary == next_event.summary %}
      {% assign is_next_match = true %}
    {% endif %}
    {% if start_ts > now_ts and is_next_match == false and later_count < later_limit %}
      {% if item_style == 'stacked' %}
      <div class="item">
        <div class="meta">
          <span class="index">•</span>
        </div>
        <div class="content">
          <span class="{{ title_classes }}" data-clamp="1">{{ event.summary | upcase }}</span>
          <span class="{{ time_classes }}">{% if event.all_day %}{{ all_day_label | default: 'ALL DAY' }}{% else %}{{ event.start }}{% endif %}</span>
        </div>
      </div>
      {% else %}
      <div class="{{ row_classes }}">
        <span class="{{ title_classes }}" data-clamp="1">{{ event.summary | upcase }}</span>
        <span class="{{ time_classes }}">{% if event.all_day %}{{ all_day_label | default: 'ALL DAY' }}{% else %}{{ event.start }}{% endif %}</span>
      </div>
      {% endif %}
      {% assign later_count = later_count | plus: 1 %}
    {% endif %}
  {% endfor %}
  {% if later_count == 0 %}
  <div class="description">{{ empty_text }}</div>
  {% endif %}
</div>
{% endtemplate %}

{% template later_panel %}
<div class="{{ panel_classes }}">
  {% render "section_label", text: "LATER", meta: meta, inverted: false, icon: icon %}
  {% render "later_items", events: events, next_event: next_event, now_ts: now_ts, later_limit: later_limit, wrapper_classes: wrapper_classes, row_classes: row_classes, title_classes: title_classes, time_classes: time_classes, empty_text: empty_text, all_day_label: all_day_label, item_style: item_style %}
</div>
{% endtemplate %}

{% template title_bar %}
<div class="title_bar">
  <span class="title md:title--large">{{ title }}</span>
  {% if instance and instance != blank %}
  <span class="instance">{{ instance }}</span>
  {% endif %}
</div>
{% endtemplate %}
