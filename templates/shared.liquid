{% comment %}
  Shared components for Calendar XL.

  The calendar data source is selected by the user via the `calendar_source`
  custom field (plugin_instance_select, plugin_keyname: google_calendar).
  Templates reference it as `calendar_source` — no hardcoded merge namespace needed.
{% endcomment %}

{% comment %} === Common setup: available to all layouts === {% endcomment %}
{% assign calendar = calendar_source %}
{% assign events = calendar.events %}
{% assign plugin_title = trmnl.plugin_settings.custom_fields_values.custom_title | default: trmnl.plugin_settings.instance_name | default: "Calendar XL" %}
{% assign now_ts = 'now' | date: '%s' | plus: 0 %}
{% assign later_limit = trmnl.plugin_settings.custom_fields_values.max_later_items | default: '3' | plus: 0 %}
{% assign show_icons = trmnl.plugin_settings.custom_fields_values.show_icons == 'true' %}
{% assign now_icon = '' %}
{% assign next_icon = '' %}
{% assign later_icon = '' %}
{% if show_icons %}
  {% assign now_icon = '●' %}
  {% assign next_icon = '→' %}
  {% assign later_icon = '+' %}
{% endif %}
{% assign time_pattern = '%-I:%M %p' %}
{% unless calendar.time_format == 'am/pm' %}
  {% assign time_pattern = '%H:%M' %}
{% endunless %}
{% assign current_date_label = calendar.today_in_tz | date: calendar.date_format | upcase %}
{% assign current_time_label = 'now' | date: time_pattern %}
{% assign current_event = blank %}
{% assign next_event = blank %}
{% assign secondary_event = blank %}
{% assign upcoming_count = 0 %}
{% for event in events %}
  {% assign start_ts = event.start_full | date: '%s' | plus: 0 %}
  {% assign end_ts = event.end_full | date: '%s' | plus: 0 %}
  {% if start_ts > now_ts %}
    {% assign upcoming_count = upcoming_count | plus: 1 %}
  {% endif %}
  {% unless event.all_day %}
    {% if current_event == blank and start_ts <= now_ts and end_ts > now_ts %}
      {% assign current_event = event %}
    {% endif %}
    {% if next_event == blank and start_ts > now_ts %}
      {% assign next_event = event %}
    {% elsif secondary_event == blank and start_ts > now_ts and next_event != blank %}
      {% assign secondary_event = event %}
    {% endif %}
  {% endunless %}
{% endfor %}
{% comment %}
  Derived display variables:
  - is_free: true when no event is active right now
  - primary_event / primary_label: when free but next event exists, promote NEXT into the hero
  - display_next_event: secondary_event when free (used by quadrant NEXT cell to avoid repeating the hero)
{% endcomment %}
{% assign is_free = false %}
{% if current_event == blank %}
  {% assign is_free = true %}
{% endif %}
{% assign primary_event = current_event %}
{% assign primary_label = 'NOW' %}
{% if is_free and next_event != blank %}
  {% assign primary_event = next_event %}
  {% assign primary_label = 'NEXT' %}
{% endif %}
{% assign display_next_event = next_event %}
{% if is_free %}
  {% assign display_next_event = secondary_event %}
{% endif %}
{% comment %} === End common setup === {% endcomment %}

{% template error_state %}
{% if size == 'full' %}
<div class="flex flex--col flex--center-x flex--center-y gap--medium h--full text--center">
  <div class="value value--large md:value--xlarge lg:value--xxlarge">CAL</div>
  <div class="title title--medium md:title--large">Calendar Merge Required</div>
  <div class="description md:title md:title--small">
    Connect a native calendar plugin, hide it in your playlist, then update this template to use the merge node from TRMNL.
  </div>
</div>
{% elsif size == 'half' %}
<div class="flex flex--col flex--center-x flex--center-y gap--small h--full text--center">
  <div class="value value--medium md:value--large">CAL</div>
  <div class="title title--small md:title--medium">Merge Required</div>
  <div class="description">Connect calendar data</div>
</div>
{% elsif size == 'quadrant' %}
<div class="flex flex--col flex--center-x flex--center-y gap--xsmall h--full text--center">
  <div class="value value--small md:value--medium">CAL</div>
  <div class="description">Need merge data</div>
</div>
{% endif %}
{% endtemplate %}

{% template section_label %}
<div class="flex flex--row flex--between flex--center-y gap--xsmall">
  <span class="label {% if inverted %}label--small label--inverted{% else %}label label--small label--underline{% endif %}">
    {% if icon and icon != blank %}{{ icon }} {% endif %}{{ text }}
  </span>
  {% if meta and meta != blank %}
  <span class="label label--small {% if inverted %}label--inverted{% endif %}">{{ meta }}</span>
  {% endif %}
</div>
{% endtemplate %}

{% template now_panel %}
<div class="{{ panel_classes }}">
  {% render "section_label", text: label | default: "NOW", meta: meta, inverted: true, icon: icon %}
  {% if event != blank %}
  <div class="{{ value_classes }}" data-value-fit="true" data-value-fit-max-height="{{ fit_height }}">{{ event.summary | upcase }}</div>
  <div class="{{ detail_classes }}">{{ event.start }} - {{ event.end }}</div>
  {% else %}
  <div class="{{ empty_value_classes | default: value_classes }}">{{ empty_value | default: 'FREE' }}</div>
  {% if empty_detail and empty_detail != blank %}
  <div class="{{ empty_detail_classes | default: detail_classes }}">{{ empty_detail }}</div>
  {% endif %}
  {% endif %}
</div>
{% endtemplate %}

{% template next_panel %}
<div class="{{ panel_classes }}">
  {% render "section_label", text: "NEXT", meta: meta, inverted: false, icon: icon %}
  {% if next_event != blank %}
  <div class="{{ title_classes }}" data-clamp="2">{{ next_event.summary | upcase }}</div>
  <div class="{{ time_classes }}">{{ next_event.start }} - {{ next_event.end }}</div>
  {% else %}
  <div class="{{ empty_title_classes | default: title_classes }}">{{ empty_title | default: 'CLEAR' }}</div>
  {% if empty_detail and empty_detail != blank %}
  <div class="{{ empty_detail_classes | default: 'description' }}">{{ empty_detail }}</div>
  {% endif %}
  {% endif %}
</div>
{% endtemplate %}

{% template later_items %}
<div class="{{ wrapper_classes }}">
  {% assign later_count = 0 %}
  {% for event in events %}
    {% assign start_ts = event.start_full | date: '%s' | plus: 0 %}
    {% assign is_next_match = false %}
    {% if next_event != blank and event.date_time == next_event.date_time and event.summary == next_event.summary %}
      {% assign is_next_match = true %}
    {% endif %}
    {% if skip_extra_event != blank and event.date_time == skip_extra_event.date_time and event.summary == skip_extra_event.summary %}
      {% assign is_next_match = true %}
    {% endif %}
    {% if start_ts > now_ts and is_next_match == false and later_count < later_limit %}
      {% if item_style == 'stacked' %}
      <div class="item">
        <div class="meta">
          <span class="index">•</span>
        </div>
        <div class="content">
          <span class="{{ title_classes }}" data-clamp="1">{{ event.summary | upcase }}</span>
          <span class="{{ time_classes }}">{% if event.all_day %}{{ all_day_label | default: 'ALL DAY' }}{% else %}{{ event.start }}{% endif %}</span>
        </div>
      </div>
      {% else %}
      <div class="{{ row_classes }}">
        <span class="{{ title_classes }}" data-clamp="1">{{ event.summary | upcase }}</span>
        <span class="{{ time_classes }}">{% if event.all_day %}{{ all_day_label | default: 'ALL DAY' }}{% else %}{{ event.start }}{% endif %}</span>
      </div>
      {% endif %}
      {% assign later_count = later_count | plus: 1 %}
    {% endif %}
  {% endfor %}
  {% if later_count == 0 %}
  <div class="description">{{ empty_text }}</div>
  {% endif %}
</div>
{% endtemplate %}

{% template later_panel %}
<div class="{{ panel_classes }}">
  {% render "section_label", text: "LATER", meta: meta, inverted: false, icon: icon %}
  {% render "later_items", events: events, next_event: next_event, now_ts: now_ts, later_limit: later_limit, wrapper_classes: wrapper_classes, row_classes: row_classes, title_classes: title_classes, time_classes: time_classes, empty_text: empty_text, all_day_label: all_day_label, item_style: item_style, skip_extra_event: skip_extra_event %}
</div>
{% endtemplate %}

{% template title_bar %}
<div class="title_bar">
  <span class="title md:title--large">{{ title }}</span>
  {% if instance and instance != blank %}
  <span class="instance">{{ instance }}</span>
  {% endif %}
</div>
{% endtemplate %}
