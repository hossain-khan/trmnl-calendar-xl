{% comment %}
  Shared components for Calendar XL.

  The calendar data source is selected by the user via the `calendar_source`
  custom field (plugin_instance_select, plugin_keyname: google_calendar).
  Templates reference it as `calendar_source` — no hardcoded merge namespace needed.
{% endcomment %}

{% comment %} === Common setup: available to all layouts === {% endcomment %}
{% assign calendar = calendar_source %}

{% comment %}
  Demo mode — controls whether synthetic sample events are shown.

  Logic:
    - demo_mode == "true"  → always show demo data (even if a calendar is connected)
    - demo_mode == "false" → always show real calendar data
    - demo_mode unset/blank → fall back to demo if no calendar is connected;
                               show real data if calendar_source is present

  This lets users with a connected calendar still toggle demo on/off to preview
  the plugin appearance without exposing personal events.
{% endcomment %}
{% assign _demo_val = trmnl.plugin_settings.custom_fields_values.demo_mode | downcase %}
{% assign _use_demo = false %}
{% if _demo_val == "true" %}
  {% assign _use_demo = true %}
{% elsif _demo_val == "false" %}
  {% assign _use_demo = false %}
{% elsif calendar_source == blank %}
  {% assign _use_demo = true %}
{% endif %}
{% if _use_demo %}
  {% assign _ns  = 'now' | date: '%s' | plus: 0 %}
  {% assign _e1s = _ns | minus: 1200  %}
  {% assign _e1e = _ns | plus: 2400  %}
  {% assign _e1b = _ns  %}
  {% assign _e1b_e = _ns | plus: 1800  %}
  {% assign _e1c = _ns | plus: 600  %}{% assign _e1c_e = _ns | plus: 3600  %}
  {% assign _e2s = _ns | plus: 7200   %}{% assign _e2e = _ns | plus: 10800 %}
  {% assign _e3s = _ns | plus: 18000  %}{% assign _e3e = _ns | plus: 21600 %}
  {% assign _e4s = _ns | plus: 28800  %}{% assign _e4e = _ns | plus: 32400 %}
  {% assign _e5s = _ns | plus: 93600  %}{% assign _e5e = _ns | plus: 97200 %}
  {% capture _demo_json %}{"events":[
    {"summary":"Team Standup","all_day":false,"status":"confirmed","calname":"Work Calendar","start":"{{ _e1s | date: '%-I:%M %p' }}","end":"{{ _e1e | date: '%-I:%M %p' }}","start_full":"{{ _e1s | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","end_full":"{{ _e1e | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","date_time":"{{ _e1s | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","location":"Conference Room B","description":""},
    {"summary":"1:1 Meeting","all_day":false,"status":"confirmed","calname":"Work Calendar","start":"{{ _e1b | date: '%-I:%M %p' }}","end":"{{ _e1b_e | date: '%-I:%M %p' }}","start_full":"{{ _e1b | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","end_full":"{{ _e1b_e | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","date_time":"{{ _e1b | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","location":"Office","description":""},
    {"summary":"Design Review","all_day":false,"status":"confirmed","calname":"Work Calendar","start":"{{ _e1c | date: '%-I:%M %p' }}","end":"{{ _e1c_e | date: '%-I:%M %p' }}","start_full":"{{ _e1c | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","end_full":"{{ _e1c_e | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","date_time":"{{ _e1c | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","location":"Meeting Room 1","description":""},
    {"summary":"Calendar XL: Product Review","all_day":false,"status":"confirmed","calname":"Work Calendar","start":"{{ _e2s | date: '%-I:%M %p' }}","end":"{{ _e2e | date: '%-I:%M %p' }}","start_full":"{{ _e2s | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","end_full":"{{ _e2e | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","date_time":"{{ _e2s | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","location":"Meeting Room 2","description":""},
    {"summary":"Fitness Class and Training","all_day":false,"status":"confirmed","calname":"Personal","start":"{{ _e3s | date: '%-I:%M %p' }}","end":"{{ _e3e | date: '%-I:%M %p' }}","start_full":"{{ _e3s | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","end_full":"{{ _e3e | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","date_time":"{{ _e3s | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","location":"Downtown Fitness Studio","description":""},
    {"summary":"Spring Break","all_day":true,"status":"confirmed","calname":"Personal","start":"{{ _ns | date: '%Y-%m-%d' }}","end":"{{ _ns | plus: 259200 | date: '%Y-%m-%d' }}","start_full":"{{ _ns | date: '%Y-%m-%d' }}","end_full":"{{ _ns | plus: 259200 | date: '%Y-%m-%d' }}","date_time":"{{ _ns | date: '%Y-%m-%d' }}","location":"","description":""},
    {"summary":"Company All-hands Day","all_day":true,"status":"confirmed","calname":"Work Calendar","start":"{{ _ns | plus: 86400 | date: '%Y-%m-%d' }}","end":"{{ _ns | plus: 172800 | date: '%Y-%m-%d' }}","start_full":"{{ _ns | plus: 86400 | date: '%Y-%m-%d' }}","end_full":"{{ _ns | plus: 172800 | date: '%Y-%m-%d' }}","date_time":"{{ _ns | plus: 86400 | date: '%Y-%m-%d' }}","location":"","description":""},
    {"summary":"Parent-Teacher Meeting","all_day":false,"status":"confirmed","calname":"Family","start":"{{ _e4s | date: '%-I:%M %p' }}","end":"{{ _e4e | date: '%-I:%M %p' }}","start_full":"{{ _e4s | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","end_full":"{{ _e4e | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","date_time":"{{ _e4s | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","location":"School Main Office","description":""},
    {"summary":"Dinner Reservation","all_day":false,"status":"confirmed","calname":"Personal","start":"{{ _e5s | date: '%-I:%M %p' }}","end":"{{ _e5e | date: '%-I:%M %p' }}","start_full":"{{ _e5s | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","end_full":"{{ _e5e | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","date_time":"{{ _e5s | date: '%Y-%m-%dT%H:%M:%S.000+00:00' }}","location":"The Grand Table","description":""}
  ],"time_format":"am/pm","today_in_tz":"now"}{% endcapture %}
  {% assign calendar = _demo_json | parse_json %}
{% endif %}
{% assign events = calendar.events %}
{% assign now_ts = 'now' | date: '%s' | plus: 0 %}


{% comment %}
  Device helpers — derived from trmnl.device.width/height (logical CSS px, matching framework breakpoints).
    device_size: 'sm' (<800) | 'md' (800–1023) | 'lg' (≥1024)
    is_portrait:  true when height > width
  Use these in templates instead of raw dimension comparisons.
  See: https://trmnl.com/api/models
{% endcomment %}
{% assign device_size = 'sm' %}
{% if trmnl.device.width >= 800 %}{% assign device_size = 'md' %}{% endif %}
{% if trmnl.device.width >= 1024 %}{% assign device_size = 'lg' %}{% endif %}
{% assign is_portrait = false %}
{% if trmnl.device.height > trmnl.device.width %}{% assign is_portrait = true %}{% endif %}
{% comment %} later_limit: portrait md/lg=4, lg landscape=3, sm/md landscape=2 {% endcomment %}
{% assign later_limit = 3 %}
{% if is_portrait and device_size != 'sm' %}
  {% assign later_limit = 4 %}
{% elsif device_size != 'lg' and is_portrait == false %}
  {% assign later_limit = 2 %}
{% endif %}
{% assign time_pattern = '%-I:%M %p' %}
{% unless calendar.time_format == 'am/pm' %}
  {% assign time_pattern = '%H:%M' %}
{% endunless %}
{% assign _date_src = calendar.today_in_tz | default: 'now' %}
{% assign current_date_label = _date_src | date: '%a, %b %-d' | upcase %}
{% assign current_time_label = 'now' | date: time_pattern %}
{% assign current_event = blank %}
{% assign next_event = blank %}
{% assign secondary_event = blank %}
{% assign upcoming_count = 0 %}
{% assign concurrent_event_count = 0 %}
{% for event in events %}
  {% assign start_ts = event.start_full | date: '%s' | plus: 0 %}
  {% assign end_ts = event.end_full | date: '%s' | plus: 0 %}
  {% if start_ts > now_ts %}
    {% assign upcoming_count = upcoming_count | plus: 1 %}
  {% endif %}
  {% unless event.all_day %}
    {% if current_event == blank and start_ts <= now_ts and end_ts > now_ts %}
      {% assign current_event = event %}
    {% endif %}
    {% if next_event == blank and start_ts > now_ts %}
      {% assign next_event = event %}
    {% elsif secondary_event == blank and start_ts > now_ts and next_event != blank %}
      {% assign secondary_event = event %}
    {% endif %}
  {% endunless %}
{% endfor %}

{% comment %} Count how many events are happening at the same time as current_event {% endcomment %}
{% if current_event != blank %}
  {% assign current_start = current_event.start_full | date: '%s' | plus: 0 %}
  {% assign current_end = current_event.end_full | date: '%s' | plus: 0 %}
  {% for event in events %}
    {% assign event_start = event.start_full | date: '%s' | plus: 0 %}
    {% assign event_end = event.end_full | date: '%s' | plus: 0 %}
    {% if event_start <= now_ts and event_end > now_ts and event.all_day == false %}
      {% assign concurrent_event_count = concurrent_event_count | plus: 1 %}
    {% endif %}
  {% endfor %}
{% endif %}


{% comment %}
  All-day events section logic
  
  When show_all_day_events setting is enabled, check for active all-day events
  (those where end_ts > now_ts). If any exist, prepare them for display instead
  of showing additional LATER items.
  
  Variables:
  - show_all_day_events_enabled: true if setting is on
  - active_all_day_events: array of current/ongoing all-day events
  - has_active_all_day: true if there are active all-day events to show
  - should_show_all_day: true if we should render ALL DAY EVENTS section
{% endcomment %}
{% assign show_all_day_events_enabled = false %}
{% if trmnl.plugin_settings.custom_fields_values.show_all_day_events == "true" %}
  {% assign show_all_day_events_enabled = true %}
{% endif %}

{% comment %} Check if there are any active all-day events {% endcomment %}
{% assign has_active_all_day = false %}
{% if show_all_day_events_enabled %}
  {% for event in events %}
    {% if event.all_day %}
      {% assign event_end_ts = event.end_full | date: '%s' | plus: 0 %}
      {% if event_end_ts > now_ts %}
        {% assign has_active_all_day = true %}
      {% endif %}
    {% endif %}
  {% endfor %}
{% endif %}
{% assign should_show_all_day = false %}
{% if show_all_day_events_enabled and has_active_all_day %}
  {% assign should_show_all_day = true %}
{% endif %}


{% comment %}
  Derived display variables:
  - is_free: true when no event is active right now
  - primary_event / primary_label: when free but next event exists, promote NEXT into the hero
  - display_next_event: secondary_event when free (used by quadrant NEXT cell to avoid repeating the hero)
{% endcomment %}
{% assign is_free = false %}
{% if current_event == blank %}
  {% assign is_free = true %}
{% endif %}
{% assign primary_event = current_event %}
{% assign primary_label = 'NOW' %}
{% if is_free and next_event != blank %}
  {% assign primary_event = next_event %}
  {% assign primary_label = 'NEXT' %}
{% endif %}
{% assign display_next_event = next_event %}
{% if is_free %}
  {% assign display_next_event = secondary_event %}
{% endif %}
{% assign title_bar_status = 'FREE NOW' %}
{% unless is_free %}
  {% assign title_bar_status = 'BUSY' %}
{% endunless %}
{% assign title_bar_status_full = title_bar_status %}
{% unless is_free %}
  {% if upcoming_count > 0 %}
    {% assign title_bar_status_full = 'BUSY · ' | append: upcoming_count | append: ' MORE' %}
  {% endif %}
{% endunless %}
{% comment %} Capitalize events by default; turn off by setting capitalize_text to false {% endcomment %}
{% assign primary_event_display = primary_event.summary | upcase %}
{% assign next_event_display = display_next_event.summary | upcase %}
{% if trmnl.plugin_settings.custom_fields_values.capitalize_text == "false" %}
  {% assign primary_event_display = primary_event.summary %}
  {% assign next_event_display = display_next_event.summary %}
{% endif %}


{% comment %}
  Smart time/date labels for the hero and NEXT panels.
  Compares the event date against today (derived from calendar.today_in_tz):
    Same day  → "12:00 PM – 1:00 PM"   (time range, as before)
    Diff day  → "MAR 19 AT 12:00 PM"   (date + start time, no end time)
    All-day   → "MAR 20"               (date only; defensive — all-day events are
                                         filtered out of next_event/display_next_event)
  These replace the hard-coded `start – end` expressions in every layout template.
{% endcomment %}
{% assign _today_ymd = _date_src | date: '%Y-%m-%d' %}
{% assign _primary_ymd = primary_event.start_full | date: '%Y-%m-%d' %}
{% if primary_event == blank %}
  {% assign primary_event_time_label = blank %}
{% elsif _primary_ymd == _today_ymd %}
  {% assign primary_event_time_label = primary_event.start | append: ' – ' | append: primary_event.end %}
{% else %}
  {% assign _pd = primary_event.start_full | date: '%b %-d' | upcase %}
  {% assign primary_event_time_label = _pd | append: ' AT ' | append: primary_event.start %}
{% endif %}

{% comment %} Append concurrent event count to time label if multiple events are happening now {% endcomment %}
{% if primary_label == 'NOW' and concurrent_event_count > 1 %}
  {% assign _more_count = concurrent_event_count | minus: 1 %}
  {% assign primary_event_time_label = primary_event_time_label | append: ' + ' | append: _more_count | append: ' more' %}
{% endif %}
{% assign _next_ymd = display_next_event.start_full | date: '%Y-%m-%d' %}
{% if display_next_event == blank %}
  {% assign next_event_time_label = blank %}
{% elsif _next_ymd == _today_ymd %}
  {% assign next_event_time_label = display_next_event.start | append: ' – ' | append: display_next_event.end %}
{% else %}
  {% assign _nd = display_next_event.start_full | date: '%b %-d' | upcase %}
  {% if display_next_event.all_day %}
    {% assign next_event_time_label = _nd %}
  {% else %}
    {% assign next_event_time_label = _nd | append: ' AT ' | append: display_next_event.start %}
  {% endif %}
{% endif %}
{% comment %} === End common setup === {% endcomment %}

{% comment %}
  Template: error_state
  Description: Renders a centered error/setup message when the calendar plugin is
               not connected or data is unavailable. Scales to the three layout sizes.
  Parameters:
  - size  {string}  Layout size bucket. Required. One of:
                    'full'     — full-screen layout
                    'half'     — half-horizontal or half-vertical layout
                    'quadrant' — quarter-size layout
  Usage:
    {% render "shared", template_name: "error_state", size: "full" %}
    {% render "shared", template_name: "error_state", size: "half" %}
    {% render "shared", template_name: "error_state", size: "quadrant" %}
{% endcomment %}
{% template error_state %}
{% if size == 'full' %}
<div class="flex flex--col flex--center-x flex--center-y gap--medium h--full text--center">
  <div class="value value--large md:value--xlarge lg:value--xxlarge">Calendar</div>
  <div class="title title--medium">Calendar Connection Required</div>
  <div class="description md:title md:title--small">
    Connect a native google calendar plugin, hide it in your playlist, then update this template with the Google Calendar you want to use.
  </div>
</div>
{% elsif size == 'half' %}
<div class="flex flex--col flex--center-x flex--center-y gap--small h--full text--center">
  <div class="value value--medium md:value--large">Calendar</div>
  <div class="title title--small md:title--medium">Calendar Connection Required</div>
  <div class="description">Connect a native google calendar plugin, hide it in your playlist, then update this template with the Google Calendar you want to use.</div>
</div>
{% elsif size == 'quadrant' %}
<div class="flex flex--col flex--center-x flex--center-y gap--xsmall h--full text--center">
  <div class="value value--small md:value--medium">Calendar</div>
  <div class="description">Calendar Connection Required</div>
</div>
{% endif %}
{% endtemplate %}


{% comment %}
  Template: section_label
  Description: Renders a horizontal label row used as a section header.
               Left side shows the primary label; right side shows optional metadata.
               Supports normal (underline) and inverted (filled) visual styles.
  Parameters:
  - text     {string}   Label text to display on the left. Required.
  - meta     {string}   Optional secondary text displayed on the right.
                        Pass blank or omit to hide the right slot.
  - inverted {boolean}  When truthy, applies label--inverted styling (filled pill).
                        Omit or pass false for the default label--underline style.
  Usage:
    {% render "shared", template_name: "section_label", text: "NOW" %}
    {% render "shared", template_name: "section_label", text: "LATER", meta: "3 events" %}
    {% render "shared", template_name: "section_label", text: "NOW", inverted: true %}
{% endcomment %}
{% template section_label %}
<div class="flex flex--row flex--between flex--center-y gap--xsmall">
  <span class="label lg:label--large {% if inverted %}label--inverted{% else %}label--underline{% endif %}">{{ text }}</span>
  {% if meta and meta != blank %}
  <span class="label lg:label--large {% if inverted %}label--inverted{% endif %}">{{ meta }}</span>
  {% endif %}
</div>
{% endtemplate %}


{% comment %}
  Template: title_bar
  Description: Renders the standard TRMNL title bar with a title and an optional
               instance/status slot. Replaces the built-in title_bar element so all
               layouts share identical markup and can pass dynamic values.
  Parameters:
  - title    {string}  Primary text shown in the title slot. Required.
                       Typically current_date_label (e.g. "TUE, MAR 18").
  - instance {string}  Optional status text shown in the instance slot.
                       Typically title_bar_status or title_bar_status_full
                       (e.g. "FREE NOW", "BUSY", "BUSY · 2 MORE").
                       Pass blank or omit to hide the instance slot.
  Usage:
    {% render "shared", template_name: "title_bar", title: current_date_label %}
    {% render "shared", template_name: "title_bar", title: current_date_label, instance: title_bar_status_full %}
{% endcomment %}
{% template title_bar %}
<div class="title_bar">
  <span class="title">{{ title }}</span>
  {% if instance and instance != blank %}
  <span class="instance">{{ instance }}</span>
  {% endif %}
</div>
{% endtemplate %}
