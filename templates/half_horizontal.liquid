<div class="layout">
  {% if calendar != blank and events != blank %}
  {% if primary_event != blank %}
    {% assign hero_meta = primary_event.start | append: " – " | append: primary_event.end %}
  {% else %}
    {% assign hero_meta = blank %}
  {% endif %}
  <div class="grid grid--cols-3 gap--small h--full">

    {% comment %} ============================================================
      LEFT COLUMN — NOW/NEXT hero (col--span-2 ≈ 67% of width)
      Two <span data-value-fit> for TRMNL OG (fit_height 110) and TRMNL X (fit_height 230)
    ============================================================ {% endcomment %}
    <div class="col--span-2 rounded--large p--2 flex flex--col gap--small text--white bg--black">

      {% render "section_label", text: primary_label, meta: hero_meta, inverted: true %}

      {% if primary_event != blank %}
      <span class="value value--xxxlarge block lg:hidden"
            data-value-fit="true"
            data-value-fit-max-height="110">{{ primary_event.summary | upcase }}</span>
      <span class="value value--xxxlarge hidden lg:block"
            data-value-fit="true"
            data-value-fit-max-height="230">{{ primary_event.summary | upcase }}</span>
      {% else %}
      <div class="value value--xxxlarge">FREE</div>
      <div class="description">Nothing scheduled today</div>
      {% endif %}

    </div>

    {% comment %} ============================================================
      RIGHT COLUMN — NEXT (1 of 3 cols ≈ 33% of width)
    ============================================================ {% endcomment %}
    <div class="flex flex--col gap--small h--full">

      <div class="outline rounded--large p--2 flex flex--col gap--xsmall grow">

        {% render "section_label", text: "NEXT", inverted: false %}

        {% if display_next_event != blank %}
        <div class="value value--xsmall md:value--small lg:value--large" data-clamp="3">{{ display_next_event.summary | upcase }}</div>
        <div class="value value--xsmall md:value--small">{{ display_next_event.start }} – {{ display_next_event.end }}</div>
        {% else %}
        <div class="title title--small">CLEAR</div>
        {% endif %}

      </div>

    </div>

  </div>
  {% else %}
  {% render "error_state", size: "half" %}
  {% endif %}
</div>

{% render "title_bar", title: current_date_label, instance: title_bar_status %}
