<div class="layout">
  {% comment %} WORKAROUND: bg--black / text--white framework utilities are not rendering
    correctly for the hero panel. cal-xl-hero uses explicit CSS to force the correct
    colors in both light and dark mode.

    The TRMNL platform adds screen--dark-mode to the outer .screen container when the
    user enables dark mode — targeting it as an ancestor here handles dark adaptation
    without any Liquid conditionals.

    To revert: remove this <style> block, remove cal-xl-hero from the hero panel div,
    and restore text--white bg--black.
  {% endcomment %}
  <style>
    .screen .cal-xl-hero            { background-color: #000 !important; color: #fff !important; }
    .screen--dark-mode .cal-xl-hero { background-color: #fff !important; color: #000 !important; }
  </style>
  {% if calendar != blank and events != blank %}
  {% assign hero_meta = primary_event_time_label %}
  <div class="grid grid--cols-3 gap--small h--full">

    {% comment %} ============================================================
      LEFT COLUMN — NOW/NEXT hero (col--span-2 ≈ 67% of width)
      Two <span data-value-fit> for TRMNL OG (fit_height 110) and TRMNL X (fit_height 230)
    ============================================================ {% endcomment %}
    <div class="col--span-2 rounded--large p--2 flex flex--col gap--small cal-xl-hero">

      {% render "section_label", text: primary_label, meta: hero_meta, inverted: true %}

      {% if primary_event != blank %}
      <span class="value value--xxxlarge text--center block lg:hidden"
            data-value-fit="true"
            data-value-fit-max-height="110">{{ primary_event_display }}</span>
      <span class="value value--xxxlarge text--center hidden lg:block"
            data-value-fit="true"
            data-value-fit-max-height="230">{{ primary_event_display }}</span>
      {% else %}
      <div class="value value--xxxlarge">FREE</div>
      <div class="description">Nothing scheduled today</div>
      {% endif %}

    </div>

    {% comment %} ============================================================
      RIGHT COLUMN — NEXT (1 of 3 cols ≈ 33% of width)
    ============================================================ {% endcomment %}
    <div class="flex flex--col gap--small h--full">

      <div class="outline rounded--large p--2 flex flex--col gap--xsmall grow">

        {% render "section_label", text: "NEXT", inverted: false %}

        {% if display_next_event != blank %}
        <div class="value text--center value--xsmall md:value--small lg:value--large" data-clamp="3">{{ next_event_display }}</div>
        <div class="value text--center value--xsmall md:value--small">{{ next_event_time_label }}</div>
        {% else %}
        <div class="title title--small">CLEAR</div>
        {% endif %}

      </div>

    </div>

  </div>
  {% else %}
  {% render "error_state", size: "half" %}
  {% endif %}
</div>

{% render "title_bar", title: current_date_label, instance: title_bar_status %}
