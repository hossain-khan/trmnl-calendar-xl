<div class="layout">
  {% comment %} WORKAROUND: bg--black / text--white framework utilities are not rendering
    correctly for the hero panel. cal-xl-hero uses explicit CSS to force the correct
    colors in both light and dark mode.

    The TRMNL platform adds screen--dark-mode to the outer .screen container when the
    user enables dark mode — targeting it as an ancestor here handles dark adaptation
    without any Liquid conditionals.

    To revert: remove this <style> block, remove cal-xl-hero from the hero panel div,
    and restore text--white bg--black.
  {% endcomment %}
  <style>
    .screen .cal-xl-hero            { background-color: #000 !important; color: #fff !important; }
    .screen--dark-mode .cal-xl-hero { background-color: #fff !important; color: #000 !important; }
  </style>
  {% if calendar != blank and events != blank %}
  {% assign hero_meta = primary_event_time_label %}

  {% comment %} ============================================================
    Single full-height hero — NOW or NEXT.
    Two <span data-value-fit> for TRMNL OG (fit_height 130) and TRMNL X (fit_height 280)
  ============================================================ {% endcomment %}
  <div class="rounded--large p--2 flex flex--col gap--small h--full cal-xl-hero">

    {% render "section_label", text: primary_label, meta: hero_meta, inverted: true %}

    {% if primary_event != blank %}
    <span class="value value--xxxlarge text--center block lg:hidden"
          data-value-fit="true"
          data-value-fit-max-height="120">{{ primary_event_display }}</span>
    <span class="value value--xxxlarge text--center hidden lg:block"
          data-value-fit="true"
          data-value-fit-max-height="260">{{ primary_event_display }}</span>
    {% else %}
    <div class="value value--xxxlarge">FREE</div>
    {% endif %}

  </div>
  {% else %}
  {% render "error_state", size: "quadrant" %}
  {% endif %}
</div>

{% render "title_bar", title: current_date_label, instance: title_bar_status %}
